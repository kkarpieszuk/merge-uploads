#!/usr/bin/env bash
#
# merge-uploads.sh — opcjonalnie rozpakowuje archiwa *-mu-plugins.zip, *-plugins.zip,
# *-themes.zip oraz *-others.zip / *-others2.zip / … (zawartość wp-content) do katalogu
# roboczego: mu-plugins/, plugins/, themes/ albo bezpośrednio (others), potem scala backup_*-uploads*.zip
# w uploads (albo uploads-tmp + rsync, gdy uploads już ma pliki).
#
# Użycie: wywołaj z katalogu z plikami backupów (skrypt działa w cwd):
#   ./merge-uploads.sh
# lub podaj ścieżkę jawnie:
#   bash merge-uploads.sh /ścieżka/do/katalogu
#

set -e

# Zwraca typ archiwum: mu-plugins | plugins | themes | others (others = zawartość do katalogu roboczego)
wp_part_for_zip() {
  local f="$1"
  if [[ "$f" == *-mu-plugins.zip ]]; then echo mu-plugins
  elif [[ "$f" == *-plugins.zip ]]; then echo plugins
  elif [[ "$f" == *-themes.zip ]]; then echo themes
  elif [[ "$f" =~ -others[0-9]*\.zip$ ]]; then echo others
  fi
}

# Archiwum -others*.zip: reszta wp-content (bez katalogu „others”) — scala zawartość do WORKDIR.
extract_others_zip_to_workdir() {
  local zip=$1
  local tmp
  tmp="$(mktemp -d --tmpdir="$WORKDIR" "merge-uploads-ex.XXXXXXXXXX")"

  if ! unzip -q -o "$zip" -d "$tmp"; then
    echo "[merge-uploads] Błąd rozpakowywania: $zip" >&2
    rm -rf "$tmp"
    return 1
  fi

  local item base any=
  while IFS= read -r -d '' item; do
    any=1
    base="${item##*/}"
    if [[ "$base" == wp-content && -d "$item" ]]; then
      cp -a "$item"/. "$WORKDIR"/
    else
      cp -a "$item" "$WORKDIR"/
    fi
  done < <(find "$tmp" -mindepth 1 -maxdepth 1 -print0 2>/dev/null)

  if [[ -z "$any" ]]; then
    echo "[merge-uploads] Ostrzeżenie: archiwum $zip jest puste." >&2
  fi

  rm -rf "$tmp"
}

# Rozpakowuje jedno archiwum do WORKDIR/<part>/ (bez scalania; nadpisuje pliki).
extract_zip_to_named_dir() {
  local zip=$1
  local part=$2
  local dest="$WORKDIR/$part"
  local tmp
  tmp="$(mktemp -d --tmpdir="$WORKDIR" "merge-uploads-ex.XXXXXXXXXX")"

  if ! unzip -q -o "$zip" -d "$tmp"; then
    echo "[merge-uploads] Błąd rozpakowywania: $zip" >&2
    rm -rf "$tmp"
    return 1
  fi

  mkdir -p "$dest"

  if [[ -d "$tmp/wp-content/$part" ]]; then
    cp -a "$tmp/wp-content/$part"/. "$dest/"
  elif [[ -d "$tmp/$part" ]]; then
    cp -a "$tmp/$part"/. "$dest/"
  else
    local found=
    while IFS= read -r -d '' dir; do
      if [[ -d "$dir" ]]; then
        cp -a "$dir"/. "$dest/"
        found=1
        break
      fi
    done < <(find "$tmp" -type d -name "$part" -print0 2>/dev/null)
    if [[ -z "$found" ]]; then
      echo "[merge-uploads] Ostrzeżenie: w $zip nie znaleziono katalogu $part (ani wp-content/$part w archiwum)." >&2
    fi
  fi

  rm -rf "$tmp"
}

# Katalog roboczy: argument lub katalog, z którego skrypt został wywołany
if [[ -n "${1:-}" ]]; then
  WORKDIR="$(cd -- "$1" && pwd)"
else
  WORKDIR="$(pwd)"
fi

cd "$WORKDIR"

# --- Opcjonalne archiwa (pytanie przed pracą nad uploads) ---
# Kolejność: najpierw *-mu-plugins.zip, potem *-plugins.zip — inaczej *-plugins.zip dopasuje też …-mu-plugins.zip.
extra_zips=()
shopt -s nullglob
for local_f in *.zip; do
  [[ -f "$local_f" ]] || continue
  if [[ "$local_f" == *-mu-plugins.zip ]]; then extra_zips+=("$local_f"); continue; fi
  if [[ "$local_f" == *-plugins.zip ]]; then extra_zips+=("$local_f"); continue; fi
  if [[ "$local_f" == *-themes.zip ]]; then extra_zips+=("$local_f"); continue; fi
  if [[ "$local_f" =~ -others[0-9]*\.zip$ ]]; then extra_zips+=("$local_f"); continue; fi
done
shopt -u nullglob

if [[ ${#extra_zips[@]} -gt 0 ]]; then
  IFS=$'\n' readarray -t extra_zips < <(printf '%s\n' "${extra_zips[@]}" | sort -V)
  echo "[merge-uploads] Wykryto dodatkowe archiwa:"
  printf '  %s\n' "${extra_zips[@]}"
  echo -n "Rozpakować je (mu-plugins/, plugins/, themes/; -others* → bieżący katalog)? [Y/n] "
  read -r reply || true
  reply="${reply,,}"
  if [[ -z "$reply" || "$reply" == y || "$reply" == yes ]]; then
    for zip in "${extra_zips[@]}"; do
      [[ -f "$zip" ]] || continue
      part="$(wp_part_for_zip "$zip")"
      [[ -n "$part" ]] || continue
      if [[ "$part" == others ]]; then
        echo "[merge-uploads] Rozpakowuję: $zip → $WORKDIR/ (zawartość jak w wp-content)"
        extract_others_zip_to_workdir "$zip"
      else
        echo "[merge-uploads] Rozpakowuję: $zip → $part/"
        extract_zip_to_named_dir "$zip" "$part"
      fi
      rm -f "$zip"
      echo "[merge-uploads] Usunięto: $zip"
    done
  else
    echo "[merge-uploads] Pomijam dodatkowe archiwa."
  fi
fi

# Gdy uploads już ma pliki — scalamy do uploads-tmp i na końcu rsync (bezpieczne scalanie).
# Gdy uploads nie istnieje lub jest pusty — scalamy od razu do uploads (bez drugiego kopiowania).
UPLOADS_HAS_CONTENT=
if [[ -d uploads ]] && [[ -n "$(find uploads -mindepth 1 -print -quit 2>/dev/null)" ]]; then
  UPLOADS_HAS_CONTENT=1
fi

if [[ -n "$UPLOADS_HAS_CONTENT" ]]; then
  MERGE_TARGET="$WORKDIR/uploads-tmp"
  if [[ -d "$MERGE_TARGET" ]]; then
    echo "[merge-uploads] Czyszczę uploads-tmp..."
    find "$MERGE_TARGET" -mindepth 1 -delete
  else
    mkdir -p "$MERGE_TARGET"
  fi
  mkdir -p uploads
else
  MERGE_TARGET="$WORKDIR/uploads"
  mkdir -p "$MERGE_TARGET"
  echo "[merge-uploads] uploads pusty — scalam bezpośrednio (bez uploads-tmp i bez końcowego kopiowania)."
fi

# Wzorzec: backup_{1}-uploads{2}.zip (np. backup_2026-03-02-xxx-uploads.zip, ...-uploads2.zip)
shopt -s nullglob
zips=( backup_*-uploads*.zip )
shopt -u nullglob

if [[ ${#zips[@]} -eq 0 ]]; then
  echo "[merge-uploads] Nie znaleziono plików backup_*-uploads*.zip w: $WORKDIR"
  exit 0
fi

echo "[merge-uploads] Znaleziono ${#zips[@]} archiwów do scalenia."

for zip in "${zips[@]}"; do
  [[ -f "$zip" ]] || continue
  echo "[merge-uploads] Przetwarzam: $zip"
  tmp="$(mktemp -d --tmpdir="$(pwd)" "merge-uploads.XXXXXXXXXX")"
  trap "rm -rf '$tmp'" EXIT

  if ! unzip -q -o "$zip" -d "$tmp"; then
    echo "[merge-uploads] Błąd rozpakowywania: $zip" >&2
    rm -rf "$tmp"
    exit 1
  fi

  if [[ -d "$tmp/uploads" ]]; then
    cp -a "$tmp/uploads"/. "$MERGE_TARGET/"
  else
    # Szukamy katalogu uploads w rozpakowanym drzewie (np. gdy zip ma inny root)
    found=
    while IFS= read -r -d '' dir; do
      if [[ -d "$dir" ]]; then
        cp -a "$dir"/. "$MERGE_TARGET/"
        found=1
        break
      fi
    done < <(find "$tmp" -type d -name uploads -print0 2>/dev/null)
    if [[ -z "$found" ]]; then
      echo "[merge-uploads] Ostrzeżenie: w archiwum $zip nie znaleziono katalogu uploads." >&2
    fi
  fi

  rm -rf "$tmp"
  trap - EXIT
  rm -f "$zip"
  echo "[merge-uploads] Scalono i usunięto: $zip"
done

if [[ -n "$UPLOADS_HAS_CONTENT" ]]; then
  echo "[merge-uploads] Synchronizuję uploads-tmp → uploads..."
  if command -v rsync &>/dev/null; then
    rsync -a --delete "$MERGE_TARGET"/ uploads/
  else
    find uploads -mindepth 1 -delete
    cp -a "$MERGE_TARGET"/. uploads/
  fi
  rm -rf "$MERGE_TARGET"
  echo "[merge-uploads] Usunięto uploads-tmp."
fi

echo "[merge-uploads] Gotowe. Zawartość w: $WORKDIR/uploads"
